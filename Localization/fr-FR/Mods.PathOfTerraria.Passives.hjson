# Passives will always be in the format
# Name:
# Tooltip:
# You do not need to generate these yourself, run the mod and it'll add the keys automatically.
# The {0} is the value of the passive

IncreasedMeleeDamagePassive: {
	Name: Maîtrise Martiale
	Tooltip: Augmente vos dégâts de mélée de 5% par niveau
}

IncreasedRangedDamagePassive: {
	Name: Maîtrise du Tir
	Tooltip: Augmente vos dégâts de distance de 5% par niveau
}

IncreasedMagicDamagePassive: {
	Name: Maîtrise des Arcanes
	Tooltip: Augmente vos dégâts de magie de 5% par niveau
}

AddedLifePassive: {
	Name: Chair Renforcée
	Tooltip: Augmente votre santé maximale de 20 par niveau
}

AddedManaPassive: {
	Name: Mana Passif
	Tooltip: Augmente votre mana maximale de 20 par niveau
}

LongRangePassive: {
	Name: Tireur d'Élite
	Tooltip: Augmente vos dégâts contre un ennemi distant de 10% par niveau
}

CloseRangePassive: {
	Name: Combattant Rapproché
	Tooltip: Augmente vos dégâts contre des ennemis proche de 10% par niveau
}

ChanceToBleedPassive: {
	Name: Danse Cramoisie
	Tooltip: Vos attaques de mélee inflige saignement, causant 5 dégâts par seconde, pour 2 (+ votre niveau) secondes.
}

DamageReductionPassive: {
	Name: Volonté de Fer
	Tooltip: Gagne 0.25% de réduction de dégâts par niveau.
}

DamageReflectionPassive: {
	Name: Extérieur épineux
	Tooltip: Renvoie 10 points de dégâts supplémentaires aux ennemis qui infligent des dégâts de contact par niveau.
}

StartPassive: {
	Name: Ancre
	Tooltip: Votre voyage commence ici
}

IncreasedSummonDamagePassive: {
	Name: Horde Renforcée
	Tooltip: Augmente tout vos dégâts d'invocation de 10% par niveau
}

IncreasedSentryDamagePassive: {
	Name: Sentinelles inébranlables
	Tooltip: Augmente les dégâts infligés par vos sentinelles de 10 % par niveau.
}

JewelSocket: {
	Name: Emplacement pour bijoux
