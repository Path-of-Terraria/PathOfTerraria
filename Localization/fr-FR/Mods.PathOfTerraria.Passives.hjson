}

IncreasedCriticalStrikeChance: {
	Name: Augmentation des chances de coup critique
	Tooltip: Augmente les chances de coup critique de 5% par niveau.
}

IncreasedCriticalStrikeMultiplier: {
	Name: Multiplicateur de coup critique augmenté
	Tooltip: Ajoute un multiplicateur de coup critique de 5% par niveau.
}

ArmorPenetrationPassive: {
