LifePotionPowerAffix.Description: "{1}{0}% pociones curativas mas fuertes"
LifePotionCapAffix.Description: "{1}{0} pociones de vida máxima "
LifePotionCooldownAffix.Description: "{1}{0}% enfriamiento de poción de mana"
ManaAffix.Description: "{1}{0} mana máximo"
ManaRegenAffix.Description: "{1}{0}% regeneración de maná"
